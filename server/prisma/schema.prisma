// Prisma schema - SQLite 版本（零配置，文件数据库）

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// 用户表
model User {
  id        String   @id @default(nanoid(12))
  phone     String?  @unique
  email     String?  @unique
  password  String?
  nickname  String   @default("新用户")
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  records Record[]
}

// 记录表
model Record {
  id        String   @id @default(nanoid(12))
  userId    String
  date      DateTime
  title     String
  memo      String   @default("")
  mediaType String   @default("PHOTO")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  media Media[]

  @@index([userId, date])
}

// 媒体文件表
model Media {
  id       String  @id @default(nanoid(12))
  recordId String
  url      String
  type     String
  size     Int
  width    Int?
  height   Int?
  sort     Int     @default(0)
  isCover  Boolean @default(false)

  record Record @relation(fields: [recordId], references: [id], onDelete: Cascade)

  @@index([recordId, sort])
}
